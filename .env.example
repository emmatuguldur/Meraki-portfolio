# Supabase (persistence — optional in dev; writes are skipped + logged if unset)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxx
# Use a sender verified in Resend; onboarding@resend.dev works for testing
FROM_EMAIL="Meraki <onboarding@resend.dev>"
ADMIN_EMAIL=merakiagencymn@gmail.com

# CORS (set to your site origin in production)
ALLOWED_ORIGIN=https://meraki-portfolio.vercel.app
